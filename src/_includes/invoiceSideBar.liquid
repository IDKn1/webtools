<script src="https://unpkg.com/lucide@latest"></script>
<script type="module">
    lucide.createIcons();
</script>
<button class="sidebar-open-btn no-print" id="sidebar-open-btn" type="button">
    <i data-lucide="panel-right-open"></i>
</button>
<aside class="sidebar no-print" id="sidebar">
    <div class="sidebar-tabs">
        <button
            class="tab-btn active"
            id="tab-info"
            title="Invoice info"
            onclick="switchTab('info')"
        >
            <i data-lucide="list"></i>
        </button>
        <button
            class="tab-btn"
            id="tab-item"
            title="Add item"
            onclick="switchTab('item')"
        >
            <i data-lucide="plus"></i>
        </button>
        <button
            class="tab-btn"
            id="tab-settings"
            title="Settings"
            onclick="switchTab('settings')"
        >
            <i data-lucide="settings"></i>
        </button>
        <button
            class="tab-btn"
            id="sidebar-close-btn"
            type="button"
        >
            <i data-lucide="panel-right-close"></i>
        </button>
    </div>

    <!-- Add Item panel -->
    <div class="sidebar-panel active" id="panel-item">
            <span class="panel-title">Add line item</span>
            <form @submit.prevent="addItem()">
                <input x-model="newItemDesc" type="text" placeholder="Description">
                <input
                    x-model="newItemQty"
                    type="text"
                    placeholder="Quantity / Hours"
                >
                <input x-model="newItemRate" type="text" placeholder="Rate">
                <button type="submit">Add item</button>
            </form>

            <div class="item-list-editor">
                <template x-for="(item, index) in items" :key="index">
                    <div class="item-row">
                        <span x-text="item.desc"></span>
                        <button type="button" @click="removeItem(index)">Remove</button>
                    </div>
                </template>
            </div>

            <span class="panel-title">Contract Related Fields</span>
            <input type="text" x-model="newElementText" placeholder="e.g. Website, Logo e.t.c.">
            <button @click="addElement()">Add</button>
            <div class="element-list-editor">
                <template x-for="(element, index) in elementsCovered" :key="index">
                    <div class="element-row">
                        <span x-text="element"></span>
                        <button type="button" @click="removeElement(index)">Remove</button>
                    </div>
                </template>
            </div>
        </div>

    <!-- Settings panel -->
    <div class="sidebar-panel" id="panel-settings">
        <span class="panel-title">Print visibility</span>
        <div class="print-settings">
            <div class="print-invoice">
                <label for="printInvoice">Include Invoice</label>
                <input
                    id="printInvoice"
                    type="checkbox"
                    name="printInvoice"
                    x-model="printInvoice"
                    @change="saveDetails()"
                >
            </div>
            <div class="print-contract">
                <label for="printContract">Include Contract</label>
                <input
                    id="printContract"
                    type="checkbox"
                    name="printContract"
                    x-model="printContract"
                    @change="saveDetails()"
                >
            </div>
        </div>
    </div>

    <!-- Info panel -->
    <div class="sidebar-panel" id="panel-info">
        <span class="panel-title">Your details</span>
        <div
            class="contact-info"
        >
            <label for="name">Your Name</label>
            <input
                id="name"
                type="text"
                name="name"
                x-model="name"
                @change="saveDetails()"
            >
            <label for="email">Email</label>
            <input
                id="email"
                type="text"
                name="email"
                x-model="email"
                @change="saveDetails()"
            >
            <label for="phone">Phone</label>
            <input
                id="phone"
                type="text"
                name="phoneNumber"
                x-model="phone"
                @change="saveDetails()"
            >
        </div>
        <div class="invoice-number">
            <label for="invoiceNumber">Invoice number</label>
            <input
                id="invoiceNumber"
                type="text"
                name="invoiceNumber"
                x-model="invoiceNumber"
                @change="saveDetails()"
            >
        </div>

        <span class="panel-title">Client</span>
        <div
            id="client-form"
        >
            <label for="companyNameVal">Company name</label>
            <input
                id="companyNameVal"
                type="text"
                name="companyName"
                x-model="companyName"
                @change="saveDetails()"
            >
            <label for="clientNameVal">Client Name</label>
            <input
                id="clientNameVal"
                type="text"
                x-model="clientName"
                @change="saveDetails()"
            >
            <label for="clientEmailVal">Client email</label>
            <input
                id="clientEmailVal"
                type="text"
                name="clientEmail"
                x-model="clientEmail"
                @change="saveDetails()"
            >
            <label for="clientLocationVal">Client location</label>
            <input
                id="clientLocationVal"
                type="text"
                name="clientLocation"
                x-model="clientLocation"
                @change="saveDetails()"
            >
        </div>

        <span class="panel-title">Totals</span>
        <div class="total-settings">
            <div class="tax-rate">
                <label for="taxed">Tax?</label>
                <input
                    id="taxed"
                    type="checkbox"
                    name="taxed"
                    x-model="taxed"
                    @change="saveDetails()"
                >
            </div>
            <div class="amount-paid">
                <label for="amountPaid">Amount already paid</label>
                <input
                    id="amountPaid"
                    type="text"
                    name="amountPaid"
                    x-model="amountPaid"
                    @change="saveDetails()"
                >
            </div>
        </div>

        <button type="button" @click="savePDF();">Download as PDF</button>
        <button type="button" @click="wipeFormDetails();">Reset Values</button>
    </div>
</aside>
