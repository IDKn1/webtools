---
title: "Invoice Generator"
---
{% layout 'base.liquid' %}

{% block style %}
<script
    defer
    src="https://cdn.jsdelivr.net/npm/alpinejs@3.15.12/dist/cdn.min.js"
></script>

<link rel="stylesheet" href="style.css">
{% endblock %}

{% block content %}
<div
    class="content"
    x-init="init()"
    x-data="{
    init() {
        const storedItems = sessionStorage.getItem('invoiceItems');
        this.items = storedItems ? JSON.parse(storedItems) : [];

        this.loadDetails();

    },
    name: '',
    email: '',
    phone: '',
    invoiceNumber: '',
    companyName: '',
    clientName: '',
    clientEmail: '',
    clientLocation: '',
    taxed: false,
    amountPaid: '',
    date: '',
    items: [],
    newItemDesc: '',
    newItemQty: '',
    newItemRate: '',

    // which document(s) should be visible when printing
    printInvoice: true,
    printContract: true,

    // contract-specific fields
    elementsCovered: [],
    newElementText: '',

    get today() {
        const d = new Date();
        return d.getFullYear() + '/' + ('0' + (d.getMonth() + 1)).slice(-2) + '/' + ('0' + d.getDate()).slice(-2);
    },

    addItem() {
        if (!this.newItemDesc || !this.newItemQty || !this.newItemRate) return;
        this.items.push({
            desc: this.newItemDesc,
            qty: this.newItemQty,
            rate: this.newItemRate
        });
        console.log(this.items)
        this.saveItems();
        this.newItemDesc = '';
        this.newItemQty = '';
        this.newItemRate = '';
    },

    removeItem(index) {
            this.items.splice(index, 1);
            this.saveItems();
        },

    addElement() {
        if (!this.newElementText) return;
        this.elementsCovered.push(this.newElementText);
        this.saveDetails();
        this.newElementText = '';
    },

    removeElement(index) {
        this.elementsCovered.splice(index, 1);
        this.saveDetails();
    },

    loadDetails() {
        const stored = sessionStorage.getItem('invoiceDetails');
        if (!stored) return;
        const details = JSON.parse(stored);
        Object.assign(this, details);
    },

    saveDetails() {
        const details = {
            name: this.name,
            email: this.email,
            phone: this.phone,
            invoiceNumber: this.invoiceNumber,
            companyName: this.companyName,
            clientName: this.clientName,
            clientEmail: this.clientEmail,
            clientLocation: this.clientLocation,
            taxed: this.taxed,
            amountPaid: this.amountPaid,
            elementsCovered: this.elementsCovered,
            printInvoice: this.printInvoice,
            printContract: this.printContract
        };
        sessionStorage.setItem('invoiceDetails', JSON.stringify(details));
    },

    saveItems() {
        sessionStorage.setItem('invoiceItems', JSON.stringify(this.items));
    },


    sidebarOpen: false,
    activeTab: 'info',
    get itemsCost() {
        return this.items.reduce((sum, item) => {
            return sum + ((parseFloat(item.qty) * parseFloat(item.rate)) || 0);
        }, 0);
    },

    get taxAmount() {
        return this.taxed ? this.itemsCost * 0.13 : 0;
    },

    get totalDue() {
        const paid = parseFloat(this.amountPaid) || 0;
        return this.itemsCost + this.taxAmount - paid;
    },
    savePDF() {
        window.print();
    },

    wipeFormDetails() {
        this.name = '';
        this.email = '';
        this.phone = '';
        this.invoiceNumber = '';
        this.companyName = '';
        this.clientName = '';
        this.clientEmail = '';
        this.clientLocation = '';
        this.taxed = false;
        this.amountPaid = '';
        this.items = [];
        this.elementsCovered = [];
        this.printInvoice = true;
        this.printContract = true;

        sessionStorage.removeItem('invoiceDetails');
        sessionStorage.removeItem('invoiceItems');
    }
}">

<!-- 850px is portrait letter print width -->
<!-- and 1090px for landscape letter -->

{% render 'invoiceDocument.liquid' %}

{% render 'contractDocument.liquid' %}

{% render 'invoiceSideBar.liquid' %}
<script src="main.js"></script>
<script src="sidebar.js"> </script>

</div>
{% endblock %}
